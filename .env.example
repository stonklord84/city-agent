# ─── Active: Postgres connection string ──────────────────────────────────────
# Used by Drizzle client, seed script, and migrations.
# For local dev: use Neon, Supabase, or any hosted Postgres.
# For production swap: replace with Aurora direct connection string (see below).
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require


# ─── Future: Aurora PostgreSQL via AWS IAM (production only) ─────────────────
# Uncomment and fill these in when switching to Aurora on Vercel.
# lib/db-aurora.ts uses these — swap lib/db/client.ts to use that pool when ready.

# PGHOST=your-cluster.cluster-xxxxxxxxxxxx.us-east-1.rds.amazonaws.com
# PGPORT=5432
# PGUSER=your_db_username
# PGDATABASE=postgres

# AWS_REGION=us-east-1
# AWS_ROLE_ARN=arn:aws:iam::123456789012:role/your-vercel-db-role
